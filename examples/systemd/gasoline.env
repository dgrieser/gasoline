# Environment for gasoline-watch.service — copy to /etc/gasoline/gasoline.env
# and `chmod 600` it (it holds the API key and, for MySQL, the DB password).
# Plain KEY=value lines, no `export`, no surrounding quotes needed.

# Tankerkönig API key (required).
TANKER_KOENIG_API_KEY=your-key

# --- Storage ---------------------------------------------------------------
# SQLite (default): path to the database file.
GASOLINE_DB_PATH=/etc/gasoline/gasoline.db

# MySQL: uncomment these (and comment out GASOLINE_DB_PATH above) to store on an
# external server instead. Set GASOLINE_MYSQL_TLS when the server requires SSL
# (true, skip-verify, or preferred).
#GASOLINE_DB_DRIVER=mysql
#GASOLINE_MYSQL_HOST=db.example.com
#GASOLINE_MYSQL_PORT=3306
#GASOLINE_MYSQL_USER=gasoline
#GASOLINE_MYSQL_PASSWORD=secret
#GASOLINE_MYSQL_DATABASE=gasoline
#GASOLINE_MYSQL_TLS=true
